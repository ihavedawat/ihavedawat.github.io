rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===== ADMIN HELPER FUNCTION =====
    // Check if user is in the admin email list
    function isAdmin(email) {
      return email in ['ihavedawat@gmail.com', 'igotdawat@gmail.com'];
    }

    // ===== Public (anyone can read) =====
    match /meals/{document=**} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin(request.auth.token.email);
    }

    match /weeklyMenu/{document=**} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin(request.auth.token.email);
    }

    // ===== Admin-only =====
    match /users/{document=**} {
      allow read, write: if request.auth != null && isAdmin(request.auth.token.email);
    }

    match /applications/{appId} {
      allow create: if true;
      allow read: if true;
      allow update: if request.auth != null && (isAdmin(request.auth.token.email) || request.resource.data.email == request.auth.token.email);
      allow delete: if request.auth != null && isAdmin(request.auth.token.email);
    }

    // ===== ORDERS COLLECTION =====
    // SECURITY CRITICAL: All order operations via Vercel API only (Admin SDK)
    // NO direct client-side order creation/modification allowed
    match /orders/{document=**} {
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.userId ||
         request.auth.token.email == resource.data.userEmail ||
         isAdmin(request.auth.token.email));

      // BLOCK ALL writes from client (only Admin SDK API can create/update)
      allow create, update, delete: if false;
    }

    // ===== WALLETS (keyed by userId) =====
    // SECURITY CRITICAL: Only users (orders) via Admin SDK, admins (topup confirm)
    // Users can READ their own wallet balance
    match /wallets/{userId} {
      // Users can only read their own wallet
      allow read: if request.auth != null && request.auth.uid == userId;

      // Admins can read all wallets for monitoring
      allow read: if request.auth != null && isAdmin(request.auth.token.email);

      // Admins can update wallets for topup confirmations
      allow update: if request.auth != null && isAdmin(request.auth.token.email);

      // Block creation/deletion
      allow create, delete: if false;
    }

    // ===== WALLET HISTORY =====
    // SECURITY CRITICAL: Only Vercel API and admins can CREATE entries
    // Users can READ their own transaction history
    match /walletHistory/{document=**} {
      // Users can read their own transaction history
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.userId ||
         request.auth.token.email == resource.data.userEmail ||
         isAdmin(request.auth.token.email));

      // Admins can create history entries (for topup confirmations)
      allow create: if request.auth != null && isAdmin(request.auth.token.email);

      // Block updates and deletes
      allow update, delete: if false;
    }

    // ===== TOP-UPS =====
    // SECURITY: Users can CREATE requests (status="pending" only).
    // Admins can confirm/reject (update). Users cannot update their own requests.
    match /topups/{document=**} {
      // Users can read their own requests; admins can read all
      allow read: if request.auth != null && 
        (request.auth.uid == resource.data.userId || 
         request.auth.token.email == resource.data.userEmail ||
         isAdmin(request.auth.token.email));
      
      // Users can create NEW topup requests (pending status)
      allow create: if request.auth != null && 
        request.auth.uid == request.resource.data.userId &&
        request.resource.data.status == "pending" &&
        request.resource.data.amount > 0;
      
      // Admins can update (confirm/reject topups)
      allow update: if request.auth != null && isAdmin(request.auth.token.email);
      
      // Only admins can delete
      allow delete: if request.auth != null && isAdmin(request.auth.token.email);
    }

    // ===== NOTIFICATIONS =====
    // SECURITY: Users and admins can create notifications
    match /notifications/{document=**} {
      // Users can create notifications with audience="admin" (to alert admins)
      // Admins can create any notification (to notify users or other admins)
      allow create: if request.auth != null &&
        (isAdmin(request.auth.token.email) ||
         (request.resource.data.audience == "admin") ||
         (request.resource.data.audience == "user" && request.resource.data.userId == request.auth.uid));

      allow read: if request.auth != null &&
        ((isAdmin(request.auth.token.email) && resource.data.audience == "admin") ||
         request.auth.uid == resource.data.userId);

      // Users can only update their own notification's read status
      allow update: if request.auth != null &&
        (isAdmin(request.auth.token.email) ||
         (request.auth.uid == resource.data.userId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(["read"])));

      // Users can delete their own notifications, admins can delete any
      allow delete: if request.auth != null &&
        (isAdmin(request.auth.token.email) ||
         request.auth.uid == resource.data.userId);
    }

    // ===== ADMIN OPERATIONS (audit trail) =====
    match /adminOperations/{document=**} {
      allow read: if request.auth != null && isAdmin(request.auth.token.email);
      allow write: if false; // Only Cloud Functions can write
    }

    // ===== Catch-all deny =====
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
